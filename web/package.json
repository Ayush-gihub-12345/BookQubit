{
  "name": "next-client-web-v1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "migrate:generate": "node scripts/migrate-data-to-d1.mjs",
    "db:migrate:local": "wrangler d1 execute bookqubit-db --local --file=../migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute bookqubit-db --local --file=../migrations/0002_seed.sql",
    "db:migrate:remote": "wrangler d1 execute bookqubit-db --remote --file=../migrations/0001_init.sql",
    "db:seed:remote": "wrangler d1 execute bookqubit-db --remote --file=../migrations/0002_seed.sql",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "firebase": "^12.12.1",
    "framer-motion": "^12.38.0",
    "next": "^15.3.2",
    "next-seo": "^7.2.0",
    "next-sitemap": "^4.2.3",
    "react": "^19.0.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-slick": "^0.31.0",
    "slick-carousel": "^1.8.1",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "@tailwindcss/postcss": "^4.1.11",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "wrangler": "^3.99.0"
  }
}
