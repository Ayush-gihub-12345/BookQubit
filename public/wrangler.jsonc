{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bookqubitdev",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "database",
      "database_id": "b7a72589-843b-4c9a-b793-27e3a1ae2b80"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "70c79257dad043be8b1401edd5d3f6d9"
    }
  ],
  // Powers automatic translation of book content into non-English languages
  // (src/lib/translate.js). No separate account setup needed — every
  // Cloudflare account has Workers AI enabled with a free usage allocation.
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "AMAZON_ASSOC_TAG": ""
  }
}
